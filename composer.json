{
    "name": "captchala/flarum",
    "description": "Protect Flarum signup, login, password reset and posts with CaptchaLa.",
    "keywords": [
        "flarum",
        "captcha",
        "captchala",
        "spam",
        "security"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "version": "1.0.0",
    "homepage": "https://captcha.la/integrations/flarum",
    "support": {
        "issues": "https://github.com/Captcha-La/captchala-flarum/issues",
        "source": "https://github.com/Captcha-La/captchala-flarum",
        "email": "supply@captcha.la"
    },
    "authors": [
        {
            "name": "CaptchaLa",
            "email": "supply@captcha.la",
            "homepage": "https://captcha.la"
        }
    ],
    "require": {
        "php": ">=8.1",
        "flarum/core": "^2.0.0",
        "captchala/captchala-php": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Captchala\\Flarum\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "CaptchaLa",
            "category": "feature",
            "icon": {
                "name": "fas fa-robot",
                "backgroundColor": "#3B82F6",
                "color": "#fff"
            }
        },
        "flarum-cli": {
            "modules": {
                "githubActions": true
            }
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "require-dev": {
        "flarum/phpstan": "^2.0.0"
    },
    "scripts": {
        "analyse:phpstan": "phpstan analyse",
        "clear-cache:phpstan": "phpstan clear-result-cache"
    },
    "scripts-descriptions": {
        "analyse:phpstan": "Run static analysis"
    },
    "minimum-stability": "beta",
    "prefer-stable": true
}
